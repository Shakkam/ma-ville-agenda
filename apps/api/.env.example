# ─── Database (PostgreSQL) ───────────────────────────────────────────
# Pooled connection used by the app at runtime (serverless-friendly).
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
# Direct (non-pooled) connection used by Prisma for migrations / db push.
# In local dev this can be the same value as DATABASE_URL.
DIRECT_DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# ─── API ─────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV="development"
# Comma-separated list of allowed CORS origins (add the deployed backoffice URL in prod).
# CORS_ORIGINS="https://ma-ville-agenda-backoffice.vercel.app"

# ─── Auth (JWT) ──────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# ─── Image storage (Vercel Blob) ─────────────────────────────────────
# When set, uploads go to Vercel Blob; when empty, they fall back to local disk (dev).
BLOB_READ_WRITE_TOKEN=""
