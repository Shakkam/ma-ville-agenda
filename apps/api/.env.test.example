# Integration tests (npm run test:integration) run against an ISOLATED Postgres
# schema named "test" — append &schema=test to your DB URLs so the prod "public"
# schema is never touched. Copy this to .env.test (gitignored) and fill in.
#
# First-time setup (creates the tables in the test schema):
#   DATABASE_URL="...&schema=test" DIRECT_DATABASE_URL="...&schema=test" npx prisma db push
#
DATABASE_URL="postgresql://USER:PASSWORD@HOST/db?sslmode=require&schema=test"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST/db?sslmode=require&schema=test"
JWT_SECRET="test-secret"
JWT_EXPIRES_IN="7d"
NODE_ENV="test"
RUN_INTEGRATION="1"
