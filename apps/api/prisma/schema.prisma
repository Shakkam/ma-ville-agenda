// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection for queries (serverless-friendly).
  url       = env("DATABASE_URL")
  // Direct connection for migrations (Prisma needs a non-pooled URL).
  // In local dev both can point to the same connection string.
  directUrl = env("DIRECT_DATABASE_URL")
}

// User model for backoffice authentication (super-admin + moderators)
model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String?    // bcrypt hashed; null while the invitation is pending
  role      String     @default("SUPER_ADMIN")
  status    String     @default("ACTIVE") // ACTIVE | INVITED

  // Invitation flow: sha256(token) stored at rest, queryable on accept.
  inviteTokenHash String?
  inviteExpiresAt DateTime?

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  events Event[]
}

// Event model
model Event {
  id          String        @id @default(cuid())
  title       String
  description String
  imageUrl    String?
  startDate   DateTime
  endDate     DateTime
  category    String
  location    String
  externalUrl String?
  status      String        @default("DRAFT")
  createdBy   String        // User ID
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user User @relation(fields: [createdBy], references: [id])

  @@index([status])
  @@index([category])
  @@index([startDate])
}
