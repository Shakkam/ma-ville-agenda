{
  "expo": {
    "name": "Ma Ville Agenda",
    "slug": "ma-ville-agenda",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2d93c4"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": false,
      "bundleIdentifier": "com.shakkamagic.mavillleagenda",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.shakkamagic.mavillleagenda",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2d93c4"
      },
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "web": {},
    "plugins": [
      "expo-router",
      "expo-notifications"
    ],
    "scheme": "mavillleagenda",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "aa024a9a-79f4-4e31-8e76-24437b7b8739"
      }
    },
    "owner": "shakkam",
    "updates": {
      "url": "https://u.expo.dev/aa024a9a-79f4-4e31-8e76-24437b7b8739"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
