{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://ma-ville-agenda-api.vercel.app/api"
      },
      "channel": "preview"
    },
    "preview-ios": {
      "autoIncrement": true,
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://ma-ville-agenda-api.vercel.app/api"
      },
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://ma-ville-agenda-api.vercel.app/api"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
